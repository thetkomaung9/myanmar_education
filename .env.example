# EduSphere Myanmar — Environment Variables
# Copy this file to .env.local and fill in the values.

# Public API base URL (exposed to the browser)
NEXT_PUBLIC_API_URL=http://localhost:4000

# Database connection string (server-side only)
DATABASE_URL=postgresql://user:password@localhost:5432/edusphere

# JWT secret for signing tokens (server-side only)
JWT_SECRET=your-jwt-secret-here

# AWS credentials for S3 file storage (server-side only)
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_S3_BUCKET=your-s3-bucket-name
